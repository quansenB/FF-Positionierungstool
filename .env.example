# OpenRouter API Key – required for /api/analyze
OPENROUTER_API_KEY=sk-or-v1-b...
# Optional: override the model (default: anthropic/claude-opus-4-5)
# OPENROUTER_MODEL=anthropic/claude-opus-4-5

# Upstash Redis – required for production rate limiting
# Add via Vercel Dashboard → Storage → Create KV Store → Connect to project
# Env vars are auto-injected by Vercel after linking:
KV_REST_API_READ_ONLY_TOKEN="ggAA...""
KV_REST_API_TOKEN="gQAA..."
KV_REST_API_URL="https:...upstash.io"
KV_URL="rediss://default:..."
REDIS_URL="rediss://default:..."

# Facebook Pixel & Conversions API – optional, for tracking
NEXT_PUBLIC_FB_PIXEL_ID=6123...
FB_ACCESS_TOKEN=EAA...
# Meta Test Event Code – remove after testing
FB_TEST_EVENT_CODE=TEST...

# Lead Webhook – optional, forwards lead data to Make/Zapier/CRM
LEAD_WEBHOOK_URL=https://hook.eu1.make.com/...
